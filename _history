52,"editorVersion":"8.0.21","text":{"main.ts":"","README.md":"","main.py":"\n","pxt.json":"{\n    \"name\": \"adder-proto-2\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\",\n    \"languageRestriction\": \"python-only\",\n    \"additionalFilePaths\": []\n}\n"}},{"timestamp":1777532565687,"editorVersion":"8.0.21","text":{"main.ts":"","README.md":"","main.py":"val2 = 0\nx2 = 0\nval1 = 0\nflashstatus = False\nismd = False\n\ndef bintodisstr(x: number):\n    bits = \"\"\n    if x == 0:\n        return \"0\"\n    while x > 0:\n        bits = str(x % 2) + bits\n        x = x // 2\n    return bits.replace(\"0\", \".\").replace(\"1\", \"#\")\ndef showstr(string: str, row: int):\n    i = 0\n    for char in string:\n        if char == \"#\":\n            led.plot(i, 0)\n        else:\n            led.unplot(i, 0)\n        i += 1\n\ndef on_forever():\n    global flashstatus, val1, val2, ismd\n    flashstatus = False if flashstatus else True\n    val1 = val1 % 32\n    val2 = val2 % 32\n    if input.is_gesture(Gesture.SHAKE):\n        val1 = 0\n        val2 = 0\n    if input.is_gesture(Gesture.SCREEN_DOWN):\n        ismd = False if ismd else True\n    line1 = bintodisstr(val1)\n    line2 = bintodisstr(val2)\n    line3 = \"#####\" if ismd else \".....\"\n    line4 = bintodisstr((val1 * val2) if ismd else (val1 + val2))\n    line5 = bintodisstr((val1 / val2) if ismd else (val1 - val2))\n    showstr(line1, 0)\n    showstr(line2, 0)\n    showstr(line3, 0)\n    showstr(line4, 0)\n    showstr(line5, 0)\n\n\n\n    \n    \nbasic.forever(on_forever)\n\ndef on_button_pressed_a():\n    global val1\n    if input.logo_is_pressed():\n        val1 += 0 - 1\n        return\n    val1 += 1\ninput.on_button_pressed(Button.A, on_button_pressed_a)\n\n\n\ndef on_button_pressed_b():\n    global val2\n    if input.logo_is_pressed():\n        val2 += 0 - 1\n        return\n    val2 += 1\ninput.on_button_pressed(Button.B, on_button_pressed_b)\n\n","pxt.json":"{\n    \"name\": \"adder-proto-2\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\",\n    \"languageRestriction\": \"python-only\"\n}\n"}},{"timestamp":1777534382568,"editorVersion":"8.0.21","text":{"main.ts":"","README.md":"","main.py":"val2 = 0\nx2 = 0\nval1 = 0\nflashstatus = False\nismd = False\n\ndef bintodisstr(x: int):\n    out = \"\"\n    for i in range(4, -1, -1):\n        out += \"#\" if (x >> i) & 1 else \".\"\n    return out\ndef showstr(string: str, row: int):\n    i = 0\n    returnstr = \"\"\n    for char in string:\n        if char == \"#\":\n            led.plot(i, row)\n            returnstr = returnstr + \"#\"\n        else:\n            led.unplot(i, row)\n            returnstr = returnstr + \".\"\n        i += 1\n    return returnstr + \"\\n\"\n\ndef on_forever():\n    global flashstatus, val1, val2, ismd\n    flashstatus = False if flashstatus else True\n    val1 = val1 % 32\n    val2 = val2 % 32\n    if (input.is_gesture(Gesture.SHAKE) or input.pin_is_pressed(TouchPin.P2)):\n        val1 = 0\n        val2 = 0\n        ismd = False\n    # if input.is_gesture(Gesture.SCREEN_DOWN):\n    if input.pin_is_pressed(TouchPin.P0):\n        ismd = True\n    elif input.pin_is_pressed(TouchPin.P1):\n        ismd = False\n    line1 = bintodisstr(val1)\n    line2 = bintodisstr(val2)\n    line3 = \"#####\" if ismd else \".....\"\n    line4 = bintodisstr((val1 * val2) if ismd else (val1 + val2))\n    line5 = bintodisstr(((val1 // val2) if val2 != 0 else (31 if flashstatus else 0)) if ismd else ((val1 - val2) if (val1 - val2)>= 0 else ((31 if flashstatus else 0))))\n    \n    res = str(val1) + \"|\" + str(val2) + \"\\n\"\n    res = res + \"Value 1: \" + showstr(line1, 0)\n    res = res + \"Value 2: \" + showstr(line2, 1)\n    res = res + \"Is md?:\" + showstr(line3, 2)\n    res = res + \"Add/Mul\" + showstr(line4, 3)\n    res = res + \"Min/Div\" + showstr(line5, 4)\n    res = res + \"\\n\"\n    print(res)\n    \n\n\n\n    \n    \nbasic.forever(on_forever)\n\ndef on_button_pressed_a():\n    global val1\n    if input.logo_is_pressed():\n        val1 -= 1\n        return\n    val1 += 1\ninput.on_button_pressed(Button.A, on_button_pressed_a)\n\n\n\ndef on_button_pressed_b():\n    global val2\n    if input.logo_is_pressed():\n        val2 -= 1\n        return\n    val2 += 1\ninput.on_button_pressed(Button.B, on_button_pressed_b)\n\n","pxt.json":"{\n    \"name\": \"adder-proto-2\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\"\n    ],\n    \"preferredEditor\": \"pyprj\",\n    \"languageRestriction\": \"python-only\"\n}\n"}}],"shares":[],"lastSaveTime":1777534382572}